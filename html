<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Research Road Map — Climate Change & Gaza</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --gold:#E8A800; --gold-dk:#C48800; --gold-lt:#FFF3CC;
  --teal:#0D7A6A; --teal-dk:#085248; --teal-lt:#D4F0EA;
  --ink:#141414; --ink2:#2A2A2A; --ink3:#444;
  --slate:#5A6472; --ash:#8A929A; --fog:#C8CDD3;
  --paper:#FAFAF8; --white:#FFFFFF;
  --red:#C0392B; --red-lt:#FDECEA;
  --green:#1A7A3A; --green-lt:#E8F5EC;
  --blue:#1A5FA0; --blue-lt:#E8F0FA;
  --amber:#D4780A; --amber-lt:#FEF3E2;
  --r:8px; --r2:14px; --r3:20px;
  --shadow:0 2px 12px rgba(0,0,0,.10);
  --shadow2:0 6px 28px rgba(0,0,0,.14);
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:#F0EDEA;font-family:'Barlow',sans-serif;font-size:13px;color:var(--ink);min-height:100vh}
.page{width:1100px;margin:0 auto;padding:28px 28px 40px}

/* ── HEADER ─────────────────────────────── */
.hdr{background:var(--ink2);border-radius:var(--r2);padding:0;margin-bottom:16px;overflow:hidden;box-shadow:var(--shadow2)}
.hdr-top{background:var(--ink);padding:10px 22px;display:flex;justify-content:space-between;align-items:center}
.hdr-badge{background:var(--gold);color:var(--ink);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;padding:3px 10px;border-radius:3px}
.hdr-meta{font-size:10.5px;color:var(--ash);display:flex;gap:16px;align-items:center}
.hdr-meta span{display:flex;align-items:center;gap:5px}
.hdr-meta .dot{width:4px;height:4px;border-radius:50%;background:var(--gold);flex-shrink:0}
.hdr-body{padding:18px 22px 20px;display:flex;gap:20px;align-items:flex-start}
.hdr-title-col{flex:1}
.hdr-title-en{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;color:var(--white);line-height:1.25;margin-bottom:8px}
.hdr-title-en em{color:var(--gold);font-style:normal}
.hdr-title-ar{font-size:14px;color:var(--fog);line-height:1.5;direction:rtl;text-align:right}
.hdr-stats{display:flex;flex-direction:column;gap:8px;min-width:200px}
.hdr-stat{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:var(--r);padding:8px 14px;text-align:center}
.hdr-stat .num{font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:700;color:var(--gold);line-height:1}
.hdr-stat .lbl{font-size:10px;color:var(--ash);margin-top:2px}
.hdr-stats-row{display:flex;gap:8px}

/* ── PROBLEM SECTION ─────────────────────── */
.prob-section{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px}
.prob-card{background:var(--white);border-radius:var(--r2);padding:0;box-shadow:var(--shadow);overflow:hidden;border:1px solid var(--fog)}
.prob-card-hdr{background:var(--gold);padding:8px 14px;display:flex;align-items:center;gap:8px}
.prob-card-hdr .icon{width:22px;height:22px;background:var(--ink);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--gold)}
.prob-card-hdr .ttl{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:.5px;text-transform:uppercase;color:var(--ink)}
.prob-card-body{padding:12px 14px}
.sector-chips{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px}
.chip{font-size:10.5px;padding:3px 9px;border-radius:20px;font-weight:500}
.chip-water{background:#E8F0FA;color:#1A5FA0;border:1px solid #B0CDF0}
.chip-agri{background:#E8F5EC;color:#1A7A3A;border:1px solid #A0D4B0}
.chip-health{background:var(--red-lt);color:var(--red);border:1px solid #F0B0AA}
.chip-gray{background:var(--fog);color:var(--slate);border:1px solid #CCC}
.stat-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid #F0EEE8}
.stat-row:last-child{border-bottom:none}
.stat-row .sk{font-size:11.5px;color:var(--slate)}
.stat-row .sv{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;color:var(--red)}
.warn-list{list-style:none;padding:0}
.warn-list li{font-size:11.5px;color:var(--ink3);padding:4px 0 4px 14px;position:relative;border-bottom:1px solid #F5F3F0}
.warn-list li:last-child{border-bottom:none}
.warn-list li::before{content:'▸';position:absolute;left:0;color:var(--red);font-size:10px;top:5px}
.warn-list li strong{color:var(--red)}

/* ── GOAL BAR ────────────────────────────── */
.goal-bar{background:linear-gradient(135deg,var(--gold),var(--gold-dk));border-radius:var(--r2);padding:14px 22px;margin-bottom:16px;display:flex;align-items:center;gap:14px;box-shadow:var(--shadow)}
.goal-label{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:16px;letter-spacing:1px;text-transform:uppercase;color:var(--ink);white-space:nowrap;background:rgba(0,0,0,.12);padding:6px 12px;border-radius:6px}
.goal-text{font-size:13px;font-weight:500;color:var(--ink2);line-height:1.5}

/* ── BODY LAYOUT ─────────────────────────── */
.body-wrap{display:flex;gap:12px}
.phase-labels{display:flex;flex-direction:column;width:54px;flex-shrink:0;gap:3px}
.phase-lbl{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:.8px;text-transform:uppercase;writing-mode:vertical-rl;transform:rotate(180deg);display:flex;align-items:center;justify-content:center;border-radius:var(--r);padding:10px 4px}
.pl-where{background:var(--gold);color:var(--ink)}
.pl-want{background:var(--teal);color:var(--white)}
.pl-how{background:var(--ink2);color:var(--gold)}
.main-col{flex:1;min-width:0}

/* ── OUTCOME BLOCK ───────────────────────── */
.outcome-blk{border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow);margin-bottom:12px}
.outcome-hdr{background:var(--ink);padding:11px 16px;display:flex;align-items:center;gap:12px}
.outcome-num{font-family:'Barlow Condensed',sans-serif;font-size:38px;font-weight:800;color:var(--gold);line-height:1;min-width:32px}
.outcome-text-col .outcome-tag{font-size:9px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:3px}
.outcome-text-col .outcome-desc{font-size:12.5px;color:var(--fog);line-height:1.4;font-weight:400}
.outputs-grid{background:var(--paper);padding:10px}
.col-hdr{display:grid;grid-template-columns:200px 14px 1fr 14px 70px 14px 70px;gap:0;margin-bottom:6px;padding:0 4px}
.col-hdr-txt{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--ash)}

/* ── OUTPUT ROW ──────────────────────────── */
.output-row{display:grid;grid-template-columns:24px 200px 14px 1fr 14px 70px 14px 70px;gap:0;align-items:center;margin-bottom:5px;cursor:pointer;transition:opacity .15s}
.output-row:hover{opacity:.92}
.step-num{font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;color:var(--teal-dk);padding-right:4px}
.out-box{background:var(--teal);color:var(--white);border-radius:var(--r);padding:9px 12px;font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:13px;line-height:1.3;min-height:48px;display:flex;align-items:center;position:relative}
.out-box .sub{display:block;font-family:'Barlow',sans-serif;font-size:10px;font-weight:400;color:rgba(255,255,255,.65);margin-top:2px}
.arrow-cell{display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--fog)}
.deliv-box{background:var(--teal-dk);color:var(--white);border-radius:var(--r);padding:7px 10px;font-size:11px;font-weight:600;line-height:1.3;min-height:48px;display:flex;align-items:center;justify-content:center;text-align:center}
.deliv-box .sub{display:block;font-size:9.5px;font-weight:400;color:rgba(255,255,255,.65);margin-top:2px}
.doc-box{border-radius:var(--r);padding:7px 8px;font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;min-height:48px;display:flex;align-items:center;justify-content:center;text-align:center;border:1.5px solid}
.doc-report{background:var(--green-lt);color:var(--green);border-color:var(--green)}
.doc-map{background:var(--blue-lt);color:var(--blue);border-color:var(--blue)}
.doc-data{background:var(--amber-lt);color:var(--amber);border-color:var(--amber)}
.connector-down{height:8px;margin-left:34px;border-left:2px dashed var(--fog)}

/* Outcome 2 teal variant */
.out2 .out-box{background:var(--blue);color:var(--white)}
.out2 .deliv-box{background:var(--blue-dk,#143D75);background:#143D75;color:var(--white)}

/* ── DETAIL PANELS ───────────────────────── */
.detail-panel{display:none;background:var(--white);border-radius:0 0 var(--r) var(--r);border:1.5px solid var(--teal);border-top:none;padding:12px 14px;margin-top:-5px;margin-bottom:5px;animation:fadeIn .2s ease}
.detail-panel.open{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.dp-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.dp-card{background:var(--paper);border-radius:var(--r);padding:10px 12px;border:1px solid #E8E5E0}
.dp-card .dp-ttl{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:.4px;text-transform:uppercase;color:var(--teal-dk);margin-bottom:6px;display:flex;align-items:center;gap:5px}
.dp-card .dp-ttl .ico{width:16px;height:16px;border-radius:4px;background:var(--teal);display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0}
.dp-list{list-style:none}
.dp-list li{font-size:11px;color:var(--ink3);padding:3px 0 3px 10px;position:relative;border-bottom:1px solid #F0EDEA}
.dp-list li:last-child{border-bottom:none}
.dp-list li::before{content:'·';position:absolute;left:0;font-size:14px;color:var(--teal);line-height:1.2}
.dp-stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.dp-stat{background:var(--teal-lt);border-radius:6px;padding:6px 8px;text-align:center}
.dp-stat .val{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:700;color:var(--teal-dk);line-height:1}
.dp-stat .lbl{font-size:9.5px;color:var(--slate);margin-top:1px}
.crop-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px}
.crop-tag{font-size:10.5px;padding:3px 8px;border-radius:4px;font-weight:500}
.crop-hi{background:#FEE8E8;color:#A32020;border:1px solid #F5B8B8}
.crop-med{background:#E8F5EC;color:#1A6030;border:1px solid #A8D8B8}
.rcp-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.rcp-card{border-radius:6px;padding:7px 9px;border:1px solid}
.rcp-26{background:#E8F5EC;border-color:#A0D4B0}
.rcp-45{background:#E8F0FA;border-color:#A0C8F0}
.rcp-60{background:#FEF3E2;border-color:#F0C878}
.rcp-85{background:#FEE8E8;border-color:#F0A8A8}
.rcp-card .rv{font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700}
.rcp-card .rt{font-size:10px;font-weight:400;margin-top:1px}

/* ── RCP COMPARISON TABLE ────────────────── */
.rcp-table{width:100%;border-collapse:collapse;margin-top:10px;font-size:11.5px}
.rcp-table th{background:var(--ink2);color:var(--white);padding:6px 10px;text-align:left;font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:11px;letter-spacing:.5px;text-transform:uppercase}
.rcp-table td{padding:6px 10px;border-bottom:1px solid #F0EDEA;vertical-align:top}
.rcp-table tr:nth-child(even) td{background:#F8F6F3}
.badge-stable{background:#E8F5EC;color:#1A6030;padding:2px 7px;border-radius:3px;font-size:10px;font-weight:600}
.badge-mod{background:#E8F0FA;color:#1A4A80;padding:2px 7px;border-radius:3px;font-size:10px;font-weight:600}
.badge-unstable{background:#FEF3E2;color:#904A08;padding:2px 7px;border-radius:3px;font-size:10px;font-weight:600}
.badge-critical{background:#FEE8E8;color:#902020;padding:2px 7px;border-radius:3px;font-size:10px;font-weight:600}

/* ── 3-LEVEL RECOMMENDATIONS ─────────────── */
.rec-levels{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:10px}
.rec-level{border-radius:var(--r);overflow:hidden;border:1px solid}
.rec-level.pol{border-color:#A0C8F0}
.rec-level.tec{border-color:#A0D4B0}
.rec-level.com{border-color:#F0B878}
.rec-lhdr{padding:8px 12px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:.5px;text-transform:uppercase;display:flex;align-items:center;gap:6px}
.rec-lhdr.pol{background:#E8F0FA;color:#1A4A80}
.rec-lhdr.tec{background:#E8F5EC;color:#1A6030}
.rec-lhdr.com{background:#FEF3E2;color:#904A08}
.rec-body{padding:8px 12px;background:var(--white)}
.rec-body li{font-size:11px;color:var(--ink3);padding:3px 0 3px 10px;position:relative;border-bottom:1px solid #F5F3F0}
.rec-body li:last-child{border-bottom:none}
.rec-body li::before{content:'→';position:absolute;left:0;color:var(--ash);font-size:10px}

/* ── FOOTER ──────────────────────────────── */
.footer{display:flex;align-items:center;justify-content:space-between;margin-top:18px;padding-top:14px;border-top:2px solid var(--gold)}
.footer-badges{display:flex;gap:10px;flex-wrap:wrap}
.fbadge{display:flex;align-items:center;gap:5px;background:var(--white);border:1px solid var(--fog);border-radius:5px;padding:4px 10px;font-size:11px;font-weight:500;color:var(--teal-dk)}
.fbadge .chk{width:16px;height:16px;background:var(--teal);border-radius:3px;display:flex;align-items:center;justify-content:center;color:var(--white);font-size:9px;flex-shrink:0}
.footer-sig{font-size:10px;color:var(--ash);text-align:right;line-height:1.6}
.footer-sig strong{color:var(--ink3)}

/* Tooltip */
.tooltip-wrap{position:relative;display:inline-block}
.tt{position:absolute;bottom:calc(100%+6px);left:50%;transform:translateX(-50%);background:var(--ink);color:var(--white);font-size:10.5px;padding:6px 10px;border-radius:6px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;z-index:100;box-shadow:var(--shadow2)}
.tt::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:var(--ink)}
.tooltip-wrap:hover .tt{opacity:1}

/* Highlight bar */
.highlight-row{background:#FFFBE8 !important}
.highlight-row .out-box{background:var(--gold-dk) !important}

/* Expand indicator */
.expand-ico{margin-left:auto;font-size:11px;color:rgba(255,255,255,.5);transition:transform .2s;flex-shrink:0}
.output-row.expanded .expand-ico{transform:rotate(90deg)}

/* Watermark ribbon */
.ribbon{position:fixed;top:0;right:0;background:var(--teal);color:white;font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:4px 40px 4px 20px;transform:rotate(0);box-shadow:var(--shadow);border-radius:0 0 0 6px;display:flex;align-items:center;gap:5px;opacity:.8}

/* Animate stat counts */
@keyframes countUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.animated{animation:countUp .5s ease both}
</style>
</head>
<body>

<div class="page">

<!-- ── HEADER ─────────────────────────── -->
<div class="hdr">
  <div class="hdr-top">
    <div class="hdr-badge">Research Road Map — Master's Thesis</div>
    <div class="hdr-meta">
      <span><div class="dot"></div> Islamic University of Gaza</span>
      <span><div class="dot"></div> Jan 2026</span>
      <span><div class="dot"></div> MEDRC Fellowship</span>
      <span><div class="dot"></div> Master of Infrastructure</span>
    </div>
  </div>
  <div class="hdr-body">
    <div class="hdr-title-col">
      <div class="hdr-title-en"><em>Climate Change</em> and Its Effects on Water-Stressed Communities<br>in Gaza's Marginalized Area — Focusing on <em>Groundwater Supply Issue</em></div>
      <div class="hdr-title-ar">التغير المناخي وتأثيراته على التجمعات السكانية التي تعاني من الإجهاد المائي في المناطق المهمشة في قطاع غزة بالتركيز على مشكلة إمدادات المياه الجوفية</div>
      <div style="margin-top:12px;display:flex;gap:20px">
        <div style="font-size:11.5px;color:var(--fog)">
          <span style="color:var(--ash)">Researcher:</span>
          <strong style="color:var(--white);margin-left:4px">Ahmad S. A. AbuAbdu</strong>
        </div>
        <div style="font-size:11.5px;color:var(--fog)">
          <span style="color:var(--ash)">Supervisor:</span>
          <strong style="color:var(--white);margin-left:4px">Prof. Dr. Husam Al-Najar</strong>
        </div>
      </div>
    </div>
    <div class="hdr-stats">
      <div class="hdr-stats-row">
        <div class="hdr-stat" style="flex:1">
          <div class="num" data-target="270">0</div>
          <div class="lbl">localities<br>surveyed</div>
        </div>
        <div class="hdr-stat" style="flex:1">
          <div class="num" data-target="25">0</div>
          <div class="lbl">municipalities<br>covered</div>
        </div>
      </div>
      <div class="hdr-stats-row">
        <div class="hdr-stat" style="flex:1">
          <div class="num" data-target="12">0</div>
          <div class="lbl">vulnerable<br>sectors</div>
        </div>
        <div class="hdr-stat" style="flex:1">
          <div class="num" style="font-size:18px">2010–<br>2022</div>
          <div class="lbl">climate data<br>period</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── PROBLEM STATEMENT ───────────────── -->
<div class="prob-section">
  <div class="prob-card">
    <div class="prob-card-hdr">
      <div class="icon">⚠</div>
      <div class="ttl">Highly Vulnerable Sectors — Water Focus</div>
    </div>
    <div class="prob-card-body">
      <div style="font-size:11px;color:var(--slate);margin-bottom:7px">12 sectors identified across Palestine/Gaza Strip. Water ranks #1:</div>
      <div class="sector-chips">
        <span class="chip chip-water">① Water</span>
        <span class="chip chip-agri">② Agriculture</span>
        <span class="chip chip-health">③ Health</span>
        <span class="chip chip-gray">④ Food Security</span>
        <span class="chip chip-gray">⑤ Coastal</span>
        <span class="chip chip-gray">⑥ Energy</span>
        <span class="chip chip-gray">⑦ Gender</span>
        <span class="chip chip-gray">+5 more</span>
      </div>
      <div class="stat-row"><span class="sk">Poverty rate (Gaza)</span><span class="sv">39%</span></div>
      <div class="stat-row"><span class="sk">Unemployment</span><span class="sv">41.5%</span></div>
      <div class="stat-row"><span class="sk">Food insecurity</span><span class="sv">47% HHs</span></div>
      <div class="stat-row"><span class="sk">Groundwater unfit for drinking</span><span class="sv">98%</span></div>
    </div>
  </div>
  <div class="prob-card">
    <div class="prob-card-hdr">
      <div class="icon">💧</div>
      <div class="ttl">Critical Groundwater Challenges</div>
    </div>
    <div class="prob-card-body">
      <ul class="warn-list">
        <li><strong>TDS exceeds 5,000 mg/L</strong> in most Gaza Strip locations — 10× WHO limit</li>
        <li><strong>Nitrate levels exceed 200 mg/L</strong> in multiple localities</li>
        <li><strong>Chloride exceeds 600 mg/L</strong> — severe salinity contamination</li>
        <li>Aquifer depth projected to reach <strong>27.77 m below sea level by 2040</strong></li>
        <li>Rainfall predicted to decrease <strong>5.2% every 20 years</strong></li>
        <li>Seawater intrusion worsening due to over-pumping + sea level rise</li>
        <li>Marginalized communities use <strong>agricultural wells</strong> for drinking</li>
      </ul>
    </div>
  </div>
</div>

<!-- ── GOAL BAR ─────────────────────────── -->
<div class="goal-bar">
  <div class="goal-label">Goal</div>
  <div class="goal-text">To contribute to Improved Wellbeing and Resilience of Vulnerable Female and Male Community Members in the Water-Stressed Communities in Gaza's Marginalized Area</div>
</div>

<!-- ── BODY ────────────────────────────── -->
<div class="body-wrap">
  <div class="phase-labels">
    <div class="phase-lbl pl-where" style="flex:5">Where Are We?</div>
    <div class="phase-lbl pl-want" style="flex:2">Where Do We Want To Go?</div>
    <div class="phase-lbl pl-how" style="flex:1">How?</div>
  </div>
  <div class="main-col">

    <!-- ───── OUTCOME 1 ───── -->
    <div class="outcome-blk">
      <div class="outcome-hdr">
        <div class="outcome-num">1</div>
